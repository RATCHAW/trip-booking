{
  "name": "trip-booking",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @trip-booking/db db:push",
    "db:studio": "turbo -F @trip-booking/db db:studio",
    "db:generate": "turbo -F @trip-booking/db db:generate",
    "db:migrate": "turbo -F @trip-booking/db db:migrate",
    "db:start": "turbo -F @trip-booking/db db:start",
    "db:watch": "turbo -F @trip-booking/db db:watch",
    "db:stop": "turbo -F @trip-booking/db db:stop",
    "db:down": "turbo -F @trip-booking/db db:down",
    "db:seed": "turbo -F @trip-booking/db db:seed",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@trip-booking/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@trip-booking/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.17.0"
}
